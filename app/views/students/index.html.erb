<div class="container mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold mb-6">My Students</h1>

  <% if @students.any? %>
    <div class="grid gap-4">
      <% @students.each do |student| %>
        <div class="bg-white rounded-lg shadow-md p-6">
          <div class="flex items-center justify-between">
            <div>
              <h2 class="text-xl font-semibold"><%= student['name'] %></h2>
              <p class="text-gray-600">Email: <%= student['email'] %></p>
              <% if student['lasid'] %>
                <p class="text-gray-600">LASID: <%= student['lasid'] %></p>
              <% end %>
              <p class="text-sm text-gray-500">Role: <%= student['role'].capitalize %></p>
            </div>
            <div class="text-right">
              <p class="text-sm text-gray-500">ID: <%= student['external_id'] %></p>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-6">
      <p class="text-yellow-800">You don't have any students assigned yet.</p>
    </div>
  <% end %>

  <div class="mt-6">
    <%= link_to "Back to Posts", posts_path, class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600" %>
  </div>
</div>