<div style="max-width: 800px; margin: 0 auto; padding: 20px;">
  <div style="margin-bottom: 30px;">
    <%= link_to "← Back to posts", posts_path, style: "color: #007bff; text-decoration: none;" %>
  </div>
  
  <article>
    <h1 style="margin-bottom: 10px;"><%= @post.title %></h1>
    <p style="color: #666; font-size: 14px; margin-bottom: 30px;">
      By <%= @post.author_name %> • <%= @post.created_at.strftime("%B %d, %Y at %I:%M %p") %>
    </p>
    
    <div style="line-height: 1.6; white-space: pre-wrap;"><%= @post.content %></div>
    
    <% if logged_in? && (current_user['external_id'] == @post.author_external_id || current_user['role'] == 'admin') %>
      <div style="margin-top: 40px; padding-top: 20px; border-top: 1px solid #ddd;">
        <%= link_to "Edit", edit_post_path(@post), style: "padding: 8px 16px; background: #28a745; color: white; text-decoration: none; border-radius: 4px; margin-right: 10px;" %>
        <%= button_to "Delete", @post, method: :delete, 
            data: { turbo_confirm: "Are you sure?" },
            style: "padding: 8px 16px; background: #dc3545; color: white; border: none; border-radius: 4px; cursor: pointer;" %>
      </div>
    <% end %>
  </article>
</div>